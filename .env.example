# Ruiz Home Services environment variables
#
# Current status:
# - Phase 3 Supabase Auth/Profile foundation code reads the public app URL,
#   Supabase URL, and publishable key.
# - The structured logger reads LOG_LEVEL.
# - Admin dashboard access reads a server-only Supabase user UUID allowlist.
# - Google OAuth provider credentials are configured in Supabase Auth, not here.
# - No server-side service-role key is read by this workspace yet.
#
# Rule:
# Add placeholder variable names here only when implementation code actually
# reads those variables. Never place real secrets in this file.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_placeholder_key
LOG_LEVEL=info
RHS_ADMIN_USER_IDS=00000000-0000-4000-8000-000000000000
